# ============================================================
# Lexiora — Variables de entorno para Docker / n8n
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena cada valor con tus credenciales reales
#   3. NUNCA subas el archivo .env al repositorio
#
# IMPORTANTE — qué va aquí vs qué va en el panel de n8n:
#
#   Este archivo solo contiene variables de INFRAESTRUCTURA:
#   configuración que Docker y n8n necesitan para arrancar.
#
#   Las API keys de servicios externos (OpenAI, Supabase,
#   WhatsApp) NO van aquí. Se ingresan directamente en:
#   n8n → menú izquierdo → Credentials → Add credential
#   n8n las cifra y guarda de forma segura usando la
#   N8N_ENCRYPTION_KEY de abajo.
# ============================================================


# ── n8n: Acceso al panel de administración ──────────────────
# Usuario y contraseña para entrar al panel n8n
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# Clave de cifrado para las credenciales almacenadas en n8n.
# Generar con: openssl rand -hex 32
# IMPORTANTE: si se pierde esta clave, las credenciales
# guardadas en n8n quedan inutilizables.
N8N_ENCRYPTION_KEY=GENERAR_CON_openssl_rand_hex_32

# URL pública donde estará disponible n8n (con https)
# Desarrollo: URL de ngrok  →  https://xxxx.ngrok-free.app
# Producción: dominio real  →  https://n8n.tudominio.cl
N8N_WEBHOOK_URL=https://TUDOMINIO


# ── Mercado Pago (pagos) ─────────────────────────────────────
# Estas variables SÍ van aquí porque se usan directamente
# en los nodos Code del workflow mediante $env('MP_ACCESS_TOKEN').
# Obtener en: mercadopago.cl → Tu negocio → Credenciales
#
# MP_ACCESS_TOKEN: credencial principal para crear preferencias y
#   consultar pagos. Usar el de PRUEBAS para sandbox, el de
#   PRODUCCIÓN para cobros reales.
MP_ACCESS_TOKEN=APP_USR-...

# MP_WEBHOOK_SECRET: clave para validar que los webhooks
#   provienen realmente de Mercado Pago.
# Obtener en: Tu negocio → Notificaciones IPN → Clave secreta
MP_WEBHOOK_SECRET=...


# ── Negocio ──────────────────────────────────────────────────
# Precio en pesos chilenos del paquete de 20 créditos
PRECIO_CLP=2990

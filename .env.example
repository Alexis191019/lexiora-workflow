# ============================================================
# Lexiora — Variables de entorno para Docker / n8n
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena cada valor con tus credenciales reales
#   3. NUNCA subas el archivo .env al repositorio
#
# IMPORTANTE — qué va aquí vs qué va en el panel de n8n:
#
#   Este archivo contiene variables de infraestructura Y las
#   credenciales que los nodos Code leen con $env('VARIABLE').
#
#   OpenAI y WhatsApp se configuran en:
#   n8n → Credentials → Add credential
#   (n8n las cifra con la N8N_ENCRYPTION_KEY de abajo)
# ============================================================


# ── n8n: Acceso al panel de administración ──────────────────
# Usuario y contraseña para entrar al panel n8n
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# Clave de cifrado para las credenciales almacenadas en n8n.
# Generar con: openssl rand -hex 32
# IMPORTANTE: si se pierde esta clave, las credenciales
# guardadas en n8n quedan inutilizables.
N8N_ENCRYPTION_KEY=GENERAR_CON_openssl_rand_hex_32

# URL pública donde estará disponible n8n (con https)
# Desarrollo: URL de ngrok  →  https://xxxx.ngrok-free.app
# Producción: dominio real  →  https://n8n.lexiora.cl
N8N_WEBHOOK_URL=https://n8n.lexiora.cl


# ── Supabase ──────────────────────────────────────────────────
# Los nodos Code los leen con $env.SUPABASE_URL y
# $env.SUPABASE_SERVICE_KEY directamente.
# Obtener en: supabase.com → proyecto → Settings → API
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...


# ── Flow (pagos) ──────────────────────────────────────────────
# Los nodos Code los leen con $env.FLOW_API_KEY, etc.
# Obtener en: flow.cl → Mi cuenta → Integración / API
FLOW_API_KEY=...
FLOW_SECRET_KEY=...
# Sandbox para pruebas; cambiar a producción cuando esté listo:
FLOW_API_URL=https://sandbox.flow.cl/api
# FLOW_API_URL=https://www.flow.cl/api


# ── Negocio ───────────────────────────────────────────────────
# Precio en pesos chilenos del paquete de 20 créditos
PRECIO_CLP=2990

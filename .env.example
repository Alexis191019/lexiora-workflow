# ============================================================
# Lexiora — Variables de entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena cada valor con tus credenciales reales
#   3. NUNCA subas el archivo .env al repositorio
# ============================================================


# ── n8n: Acceso al panel de administración ──────────────────
# Usuario y contraseña para entrar a http://tu-dominio.com
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# Clave de cifrado para las credenciales almacenadas en n8n.
# Generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=GENERAR_CON_openssl_rand_hex_32

# URL pública donde estará disponible n8n (con https)
# Ejemplo: https://n8n.tudominio.cl
N8N_WEBHOOK_URL=https://TUDOMINIO


# ── OpenAI ──────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...


# ── Supabase ────────────────────────────────────────────────
# Obtener en: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service Role Key (NO la anon key)


# ── WhatsApp Business API ────────────────────────────────────
# Obtener en: Meta for Developers → WhatsApp → Getting Started
WHATSAPP_API_TOKEN=EAA...
WHATSAPP_PHONE_NUMBER_ID=1234567890


# ── Flow (pagos en Chile) ────────────────────────────────────
# Obtener en: https://www.flow.cl/app/web/dashboard (o sandbox)
FLOW_API_KEY=...
FLOW_SECRET_KEY=...

# Usar sandbox para pruebas, producción para cobros reales
FLOW_API_URL=https://sandbox.flow.cl/api
# FLOW_API_URL=https://www.flow.cl/api


# ── Negocio ──────────────────────────────────────────────────
# Precio en pesos chilenos del paquete de 20 créditos
PRECIO_CLP=2990
